{
	"name": "stellarized",
	"displayName": "Stellarized",
	"description": "✦ Painting Visual Studio Code With Stars & Galaxies ✦",
	"version": "0.1.0",
	"publisher": "bearl",
	"author": "bearl (https://github.com/Brian-Earl)",
	"homepage": "https://github.com/Brian-Earl/everforest-vscode",
	"repository": {
		"type": "git",
		"url": "https://github.com/Brian-Earl/everforest-vscode.git"
	},
	"bugs": {
		"url": "https://github.com/Brian-Earl/everforest-vscode/issues"
	},
	"license": "MIT",
	"icon": "icon.png",
	"keywords": [
		"theme",
		"color-theme",
		"light",
		"dark"
	],
	"galleryBanner": {
		"color": "#e3d1c5",
		"theme": "light"
	},
	"categories": [
		"Themes"
	],
	"extensionKind": [
		"ui",
		"workspace"
	],
	"capabilities": {
		"untrustedWorkspaces": {
			"supported": true
		},
		"virtualWorkspaces": true
	},
	"main": "dist/index.js",
	"contributes": {
		"themes": [
			{
				"label": "Stellarized Dark",
				"uiTheme": "vs-dark",
				"path": "./themes/stellarized-dark.json"
			},
			{
				"label": "Stellarized Light",
				"uiTheme": "vs",
				"path": "./themes/stellarized-light.json"
			},
			{
				"label": "Cosmic Latte Dark",
				"uiTheme": "vs-dark",
				"path": "./themes/cosmic-latte-dark.json"
			},
			{
				"label": "Cosmic Latte Light",
				"uiTheme": "vs",
				"path": "./themes/cosmic-latte-light.json"
			},
			{
				"label": "Everforest Dark",
				"uiTheme": "vs-dark",
				"path": "./themes/everforest-dark.json"
			},
			{
				"label": "Everforest Light",
				"uiTheme": "vs",
				"path": "./themes/everforest-light.json"
			},
			{
				"label": "Evergarden Spring",
				"uiTheme": "vs-dark",
				"path": "./themes/evergarden-spring.json"
			},
			{
				"label": "Evergarden Summer",
				"uiTheme": "vs",
				"path": "./themes/evergarden-summer.json"
			},
			{
				"label": "Evergarden Fall",
				"uiTheme": "vs-dark",
				"path": "./themes/evergarden-fall.json"
			},
			{
				"label": "Evergarden Winter",
				"uiTheme": "vs-dark",
				"path": "./themes/evergarden-winter.json"
			},
			{
				"label": "Evergarden Lunar",
				"uiTheme": "vs-dark",
				"path": "./themes/evergarden-lunar.json"
			},
			{
				"label": "Rusticated",
				"uiTheme": "vs",
				"path": "./themes/rusticated.json"
			},
			{
				"label": "Sanctuary Ink Vault",
				"uiTheme": "vs",
				"path": "./themes/sanctuary-ink-vault.json"
			},
			{
				"label": "Sanctuary Morning Sun",
				"uiTheme": "vs",
				"path": "./themes/sanctuary-morning-sun.json"
			},
			{
				"label": "Night in the Sanctuary",
				"uiTheme": "vs-dark",
				"path": "./themes/sanctuary-night.json"
			},
			{
				"label": "Stargazing in the Sanctuary",
				"uiTheme": "vs-dark",
				"path": "./themes/sanctuary-stargazing.json"
			},
			{
				"label": "Lunaria Soft Light",
				"uiTheme": "vs",
				"path": "./themes/lunaria-soft-light.json"
			},
			{
				"label": "Lunaria Vivid Light",
				"uiTheme": "vs",
				"path": "./themes/lunaria-vivid-light.json"
			},
			{
				"label": "Olive CRT Dark",
				"uiTheme": "vs-dark",
				"path": "./themes/olive-crt-dark.json"
			},
			{
				"label": "Olive CRT Light",
				"uiTheme": "vs",
				"path": "./themes/olive-crt-light.json"
			},
			{
				"label": "Scholar Dark",
				"uiTheme": "vs-dark",
				"path": "./themes/scholar-dark.json"
			},
			{
				"label": "Scholar Light",
				"uiTheme": "vs",
				"path": "./themes/scholar-light.json"
			},
			{
				"label": "Rusticated (Simple)",
				"uiTheme": "vs",
				"path": "./themes/rusticated-simple.json"
			},
			{
				"label": "Stellarized Dark (Simple)",
				"uiTheme": "vs-dark",
				"path": "./themes/stellarized-dark-simple.json"
			},
			{
				"label": "Stellarized Light (Simple)",
				"uiTheme": "vs",
				"path": "./themes/stellarized-light-simple.json"
			},
			{
				"label": "Everforest Dark (Simple)",
				"uiTheme": "vs-dark",
				"path": "./themes/everforest-dark-simple.json"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"clean": "rimraf dist *.vsix",
		"compile:ts": "tsc",
		"compile:themes": "node dist/hook/generateThemes.js",
		"compile": "npm run clean && npm run compile:ts && npm run compile:themes",
		"package": "vsce package && git checkout -- themes",
		"lint": "eslint . --ext .ts"
	},
	"lint-staged": {
		"*.ts": "eslint --fix",
		"*.{js,json,md}": "prettier --write"
	},
	"engines": {
		"vscode": "^1.55.0"
	},
	"devDependencies": {
		"@types/color": "^4.2.0",
		"@types/node": "^18.19.130",
		"@types/vscode": "1.55.0",
		"@typescript-eslint/eslint-plugin": "5.46.1",
		"@typescript-eslint/parser": "5.46.1",
		"@vscode/test-web": "0.0.33",
		"@vscode/vsce": "^2.15.0",
		"color": "^4.2.3",
		"eslint": "8.29.0",
		"eslint-config-prettier": "8.5.0",
		"eslint-plugin-prettier": "4.2.1",
		"lint-staged": "13.1.0",
		"prettier": "2.8.1",
		"rimraf": "3.0.2",
		"typescript": "4.9.4"
	}
}
