			},
			{
				"label": "Evergarden Lunar",
				"uiTheme": "vs-dark",
				"path": "./themes/evergarden-lunar.json"
			},
			{
				"label": "Rusticated",
				"uiTheme": "vs",
				"path": "./themes/rusticated.json"
			},
			{
				"label": "Sanctuary Ink Vault",
				"uiTheme": "vs",
				"path": "./themes/sanctuary-ink-vault.json"
