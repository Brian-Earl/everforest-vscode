    {
      "name": "Class",
      "scope": "entity.name.type.class, support.class, entity.name.class, entity.other.inherited-class, storage.class",
      "settings": {
        "foreground": "#513E56"
      }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#366994"
      }
    },
    {
      "name": "Boolean",
