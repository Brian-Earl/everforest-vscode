    {
      "name": "Class",
      "scope": "entity.name.type.class, support.class, entity.name.class, entity.other.inherited-class, storage.class",
      "settings": {
        "foreground": "#9B85BB"
      }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#5496BD"
      }
    },
    {
      "name": "Boolean",
      "scope": "constant.language.boolean",
      "settings": {
        "foreground": "#5496BD"
      }
    },
    {
